{
  "name": "ast-search",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "dev": "npx tsc --watch",
    "debug:vue": "npx tsc && node ./build/main.js 'setup > this' --dir src/__tests__/dummyFiles",
    "debug:react": "npx tsc && node ./build/main.js 'useState' --dir src/__tests__/dummyFiles",
    "debug:empty": "npx tsc && node ./build/main.js 'ValidationsTab > this' --dir src/__tests__/dummyFiles",
    "debug:basics": "npx tsc && node ./build/main.js 'arrowFunction' --dir src/__tests__/dummyFiles",
    "test": "jest",
    "build": "npx tsc && cp build/main.js ast-search",
    "prepublishOnly": "npx tsc && npm test"
  },
  "type": "module",
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@babel/parser": "^7.24.4",
    "@babel/types": "^7.24.0",
    "esquery": "^1.7.0",
    "yargs": "^17.7.2"
  },
  "bin": {
    "ast-search": "./build/main.js"
  },
  "files": [
    "build/",
    "README.md"
  ],
  "pkg": {
    "targets": [
      "node18",
      "macos-x64"
    ]
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.24.1",
    "@jest/globals": "^29.7.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@types/esquery": "^1.5.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "memfs": "^4.8.1",
    "semantic-release": "^24.0.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
