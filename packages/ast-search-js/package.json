{
  "name": "ast-search-js",
  "version": "1.1.0",
  "description": "AST-based code search for JavaScript, TypeScript, and Vue",
  "main": "build/main.js",
  "exports": {
    ".": {
      "import": "./build/main.js",
      "types": "./build/main.d.ts"
    },
    "./plugin": {
      "import": "./build/plugin.js",
      "types": "./build/plugin.d.ts"
    }
  },
  "scripts": {
    "dev": "npx tsc --watch",
    "debug:vue": "npx tsc && node ./build/main.js 'setup > this' --dir src/__tests__/dummyFiles",
    "debug:react": "npx tsc && node ./build/main.js 'useState' --dir src/__tests__/dummyFiles",
    "debug:empty": "npx tsc && node ./build/main.js 'ValidationsTab > this' --dir src/__tests__/dummyFiles",
    "debug:basics": "npx tsc && node ./build/main.js 'arrowFunction' --dir src/__tests__/dummyFiles",
    "test": "jest --testPathPattern='src/__tests__'",
    "build": "npx tsc",
    "prepublishOnly": "npx tsc"
  },
  "keywords": [
    "ast",
    "ast-search",
    "code-search",
    "refactor",
    "codemod",
    "esquery",
    "babel",
    "javascript",
    "typescript",
    "vue",
    "static-analysis",
    "cli",
    "agent",
    "llm-tool",
    "mcp"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "author": "shiplet",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/willey-shiplet/ast-search.git",
    "directory": "packages/ast-search-js"
  },
  "dependencies": {
    "@babel/parser": "^7.24.4",
    "@babel/types": "^7.24.0",
    "esquery": "^1.7.0",
    "yargs": "^17.7.2"
  },
  "bin": {
    "ast-search": "./build/main.js"
  },
  "files": [
    "build/*.js",
    "build/*.d.ts",
    "build/helpers/*.js",
    "build/backends/**/*.js",
    "README.md",
    "AGENTS.md"
  ],
  "pkg": {
    "targets": [
      "node18",
      "macos-x64"
    ]
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.24.1",
    "@jest/globals": "^29.7.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/npm": "^13.1.3",
    "@types/esquery": "^1.5.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "memfs": "^4.8.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
